# VPN Config Parser — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.

# GitHub token — used for:
#  1. Fetching sources (5000 req/h with token vs 60 without)
#  2. Publishing the subscription file back to your repo
# Get it from: https://github.com/settings/tokens (classic token with repo scope)
GITHUB_TOKEN=

# GitHub owner/repo for publishing the subscription file
# In GitHub Actions these are auto-set from the workflow context.
# For local runs, set them manually.
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# LLM API key for fallback parsing (Gemini)
# The key you provided goes here.
# Provider: gemini (Google AI Studio OpenAI-compatible endpoint)
# Models: gemini-2.0-flash (default), gemini-2.0-flash-lite, gemini-1.5-flash
LLM_API_KEY=

# Telegram bot notifications (optional)
# The bot sends a summary (config count + fun fact) after each pipeline run.
# Create a bot with @BotFather, get the token, and find your chat ID
# (e.g. via @userinfobot or by messaging the bot and checking getUpdates).
# Leave empty to skip Telegram notifications entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SOCKS5 proxy for validation (optional)
# Route TCP/TLS checks through a proxy so VPN servers don't block data-center IPs.
# Format: socks5://user:pass@host:port  or  socks5://host:port
# Leave empty for direct connections.
VALIDATOR_PROXY=
